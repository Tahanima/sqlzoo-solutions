-- SQL for Question 11
SELECT name
FROM world
WHERE name LIKE capital;

-- SQL for Question 12
SELECT name
FROM world
WHERE capital LIKE concat(name, '%City');

-- SQL for Question 13
SELECT capital, name
FROM world
WHERE capital LIKE concat('%', name, '%');

-- SQL for Question 14
SELECT capital, name
FROM world
WHERE capital LIKE concat(name,'%_');

-- SQL for Question 15
SELECT name, REPLACE(capital, name, '')
FROM world
WHERE capital LIKE concat(name, '%_');
